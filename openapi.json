{
  "openapi": "3.0.1",
  "info": {
    "title": "ReadPoint Auth Service API",
    "description": "구글 인증 및 JWT 발급 마이크로서비스 API 명세",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://<your-auth-service-function-app>.azurewebsites.net/api",
      "description": "배포된 Auth Service Azure Function App 주소"
    }
  ],
  "paths": {
    "/auth/user/google": {
      "get": {
        "summary": "일반 사용자 구글 로그인 리다이렉트 URL 생성",
        "description": "구글 OAuth 로그인 페이지로 리다이렉트하는 URL을 반환하거나 302 리다이렉트합니다.",
        "responses": {
          "302": {
            "description": "구글 로그인 페이지로 리다이렉트"
          }
        }
      }
    },
    "/auth/user/google/callback": {
      "get": {
        "summary": "일반 사용자 구글 로그인 콜백",
        "description": "구글 OAuth 인증 완료 후 수신되는 콜백 엔드포인트입니다. JWT 토큰을 발급합니다.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "description": "구글 인가 코드",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "로그인 성공 및 JWT 토큰 반환",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "token": { "type": "string" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "email": { "type": "string" },
                        "nickname": { "type": "string" },
                        "role": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청 (인가 코드 누락 등)"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/auth/admin/google": {
      "get": {
        "summary": "관리자 구글 로그인 리다이렉트 URL 생성",
        "description": "관리자용 구글 OAuth 로그인 페이지로 리다이렉트하는 URL을 반환하거나 302 리다이렉트합니다.",
        "responses": {
          "302": {
            "description": "관리자 구글 로그인 페이지로 리다이렉트"
          }
        }
      }
    },
    "/auth/admin/google/callback": {
      "get": {
        "summary": "관리자 구글 로그인 콜백",
        "description": "관리자용 구글 OAuth 인증 완료 후 수신되는 콜백 엔드포인트입니다. ADMIN 권한의 JWT 토큰을 발급합니다.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "description": "구글 인가 코드",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "로그인 성공 및 JWT 토큰 반환",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "token": { "type": "string" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "email": { "type": "string" },
                        "nickname": { "type": "string" },
                        "role": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/auth/admin/approve": {
      "post": {
        "summary": "관리자 가입 승인 처리 (POST)",
        "description": "MS Teams 채널 등으로부터 전달받은 보안 서명 토큰을 대조 검증하여 관리자 가입 승인(approved = true)을 완료합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "description": "승인할 관리자 이메일"
                  },
                  "token": {
                    "type": "string",
                    "description": "HMAC 보안 서명 토큰"
                  }
                },
                "required": ["email", "token"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "승인 처리 완료"
          },
          "400": {
            "description": "필수 파라미터 누락"
          },
          "403": {
            "description": "유효하지 않은 서명 토큰"
          },
          "404": {
            "description": "존재하지 않는 관리자 이메일"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      },
      "get": {
        "summary": "관리자 가입 승인 처리 (GET)",
        "description": "이메일 링크 클릭을 통한 GET 요청을 받아 보안 서명 토큰을 대조 검증하여 관리자 가입 승인을 완료하고 안내 HTML을 응답합니다.",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "description": "승인할 관리자 이메일",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "HMAC 보안 서명 토큰",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "승인 처리 완료 (HTML 응답)",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "필수 파라미터 누락"
          },
          "403": {
            "description": "유효하지 않은 서명 토큰"
          },
          "404": {
            "description": "존재하지 않는 관리자 이메일"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    },
    "/auth/withdraw": {
      "delete": {
        "summary": "일반 사용자 회원탈퇴",
        "description": "일반 사용자 계정을 완전히 삭제하고 독서 로그를 정리합니다. 관리자 계정은 회원탈퇴를 차단합니다.",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "description": "Bearer 사용자 JWT 토큰",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "회원탈퇴 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "email": { "type": "string" },
                        "nickname": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "인증 토큰 누락"
          },
          "403": {
            "description": "관리자 계정 회원탈퇴 요청 차단"
          },
          "404": {
            "description": "존재하지 않는 유저"
          },
          "500": {
            "description": "서버 내부 오류"
          }
        }
      }
    }
  }
}
